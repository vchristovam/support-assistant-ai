# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-06-01

# Databricks
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_SQL_WAREHOUSE_ID=
DATABRICKS_GENIE_SPACE_ID=

# Dynatrace
DYNATRACE_URL=
DYNATRACE_API_TOKEN=

# Azure AI Search (Knowledge)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development

# CORS (comma-separated values)
# Leave CORS_ALLOWED_ORIGINS empty to allow all origins in development.
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-User-Id,Last-Event-ID
CORS_EXPOSE_HEADERS=Content-Location,Location,X-Request-Id
CORS_MAX_AGE=86400
